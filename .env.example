# Copy to .env and fill in. .env is gitignored; this .example is committed.

# Web3Forms access key for the contact job-ticket form (ContactLayer.jsx).
# Create one (free) at https://web3forms.com — enter the inbox you want
# submissions delivered to. Until hello@preston-gray.com forwarding is live
# (Cloudflare Email Routing — see docs/cloudflare-migration.md), point the key
# at a Gmail you definitely receive. The key is public by design (it ships in
# the client bundle); it only authorizes submissions to YOUR inbox.
# Also set this in the host's env vars (Cloudflare Pages → Settings → env vars).
VITE_WEB3FORMS_KEY=

# Privacy-friendly analytics (Plausible), DEFAULT OFF. Leave unset to keep off.
# VITE_ANALYTICS=plausible
